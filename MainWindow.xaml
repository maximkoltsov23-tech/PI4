<Window x:Class="PI4.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PI4"
        mc:Ignorable="d"
        Title="Team Task Board" Height="720" MinHeight="620" Width="1180" MinWidth="980">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Margin="0,0,0,14">
            <StackPanel DockPanel.Dock="Left">
                <TextBlock Text="Team Task Board" FontSize="28" FontWeight="SemiBold" />
                <TextBlock Text="Локальная MVVM-демонстрация совместной доски задач" Foreground="{StaticResource MutedBrush}" />
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Bottom">
                <TextBox Width="230"
                         Text="{Binding NewColumnTitle, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="Название новой колонки" />
                <Button Content="Добавить колонку" Command="{Binding AddColumnCommand}" />
                <Button Content="Сохранить" Command="{Binding SaveCommand}" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding Columns}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Width="285" Margin="0,0,14,0" Padding="12" Background="{StaticResource PanelBrush}" BorderBrush="#D2DCE8" BorderThickness="1">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                        <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontWeight="SemiBold" FontSize="15" Margin="0,0,8,0" />
                                        <Button DockPanel.Dock="Right"
                                                Content="X"
                                                Width="34"
                                                Command="{Binding DataContext.DeleteColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}"
                                                Style="{StaticResource DangerButton}" />
                                    </DockPanel>

                                    <DockPanel Grid.Row="1" Margin="0,0,0,10">
                                        <TextBox Text="{Binding NewCardTitle, UpdateSourceTrigger=PropertyChanged}" ToolTip="Название новой карточки" />
                                        <Button DockPanel.Dock="Right"
                                                Content="+"
                                                Width="40"
                                                Command="{Binding DataContext.AddCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                CommandParameter="{Binding}" />
                                    </DockPanel>

                                    <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding Cards}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="0,0,0,10" Padding="10" Background="{StaticResource SurfaceBrush}" BorderBrush="#D8E1EB" BorderThickness="1">
                                                        <StackPanel>
                                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="{Binding Description}" Margin="0,5,0,0" Foreground="{StaticResource MutedBrush}" TextWrapping="Wrap" MaxHeight="42" />
                                                            <DockPanel Margin="0,9,0,0">
                                                                <TextBlock DockPanel.Dock="Left" Text="{Binding Assignee}" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" />
                                                                <TextBlock DockPanel.Dock="Right" Text="{Binding Priority}" Foreground="{StaticResource MutedBrush}" HorizontalAlignment="Right" />
                                                            </DockPanel>
                                                            <TextBlock Text="{Binding DueDate, StringFormat=Срок: {0}}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,8" />
                                                            <WrapPanel>
                                                                <Button Content="←"
                                                                        Width="34"
                                                                        Command="{Binding DataContext.MoveCardLeftCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButton}" />
                                                                <Button Content="→"
                                                                        Width="34"
                                                                        Command="{Binding DataContext.MoveCardRightCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource SecondaryButton}" />
                                                                <Button Content="Править"
                                                                        Command="{Binding DataContext.EditCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}" />
                                                                <Button Content="Удалить"
                                                                        Command="{Binding DataContext.DeleteCardCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        CommandParameter="{Binding}"
                                                                        Style="{StaticResource DangerButton}" />
                                                            </WrapPanel>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <Grid Grid.Column="1" Margin="10,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" BorderBrush="#D2DCE8" BorderThickness="1" Padding="14" Margin="0,0,0,14">
                    <StackPanel>
                        <TextBlock Text="Пользователи онлайн" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <ItemsControl ItemsSource="{Binding OnlineUsers}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,0,0,8">
                                        <Ellipse Width="9" Height="9" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" />
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding Role, StringFormat=  ·  {0}}" Foreground="{StaticResource MutedBrush}" />
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="{StaticResource SurfaceBrush}" BorderBrush="#D2DCE8" BorderThickness="1" Padding="14">
                    <StackPanel>
                        <TextBlock Text="Детали карточки" FontSize="17" FontWeight="SemiBold" Margin="0,0,0,10" />
                        <TextBlock Text="Выберите карточку кнопкой «Править»." Foreground="{StaticResource MutedBrush}" Margin="0,0,0,12">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SelectedCard}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel DataContext="{Binding SelectedCard}">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <TextBlock Text="Название" Foreground="{StaticResource MutedBrush}" />
                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                            <TextBlock Text="Описание" Foreground="{StaticResource MutedBrush}" />
                            <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" Height="96" Margin="0,4,0,10" />
                            <TextBlock Text="Исполнитель" Foreground="{StaticResource MutedBrush}" />
                            <TextBox Text="{Binding Assignee, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,10" />
                            <TextBlock Text="Приоритет" Foreground="{StaticResource MutedBrush}" />
                            <ComboBox SelectedValue="{Binding Priority, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Content" Margin="0,4,0,10">
                                <ComboBoxItem Content="Низкий" />
                                <ComboBoxItem Content="Средний" />
                                <ComboBoxItem Content="Высокий" />
                            </ComboBox>
                            <TextBlock Text="Срок" Foreground="{StaticResource MutedBrush}" />
                            <TextBox Text="{Binding DueDate, UpdateSourceTrigger=PropertyChanged}" Margin="0,4,0,12" />
                        </StackPanel>

                        <WrapPanel>
                            <Button Content="Сохранить" Command="{Binding SaveCommand}" />
                            <Button Content="Закрыть" Command="{Binding ClearSelectionCommand}" Style="{StaticResource SecondaryButton}" />
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Foreground="{StaticResource MutedBrush}" Margin="0,12,0,0" />
    </Grid>
</Window>
